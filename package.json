{
  "name": "ai-course-platform",
  "version": "1.0.0",
  "description": "60-Day AI Product Leadership Course Platform",
  "type": "module",
  "scripts": {
    "sync:dry": "DRY_RUN=true node scripts/sync-companies.mjs",
    "sync:live": "node scripts/sync-companies.mjs",
    "jobs:check": "node scripts/daily-jobs-check.mjs",
    "freshness:dry": "DRY_RUN=true SKIP_AI=true node scripts/content-freshness-check.mjs",
    "freshness:check": "node scripts/content-freshness-check.mjs",
    "freshness:backfill": "MODE=backfill node scripts/content-freshness-check.mjs",
    "notify:gaps:dry": "DRY_RUN=true node scripts/weekly-gap-detector.mjs",
    "notify:gaps": "node scripts/weekly-gap-detector.mjs",
    "notify:jobs:dry": "DRY_RUN=true node scripts/weekly-job-alerts.mjs",
    "notify:jobs:test": "DRY_RUN=true TEST_EMAIL=stavanm@gmail.com node scripts/weekly-job-alerts.mjs",
    "notify:jobs": "node scripts/weekly-job-alerts.mjs",
    "notify:interview:dry": "DRY_RUN=true node scripts/weekly-interview-prep.mjs",
    "notify:interview:test": "DRY_RUN=true TEST_EMAIL=stavanm@gmail.com node scripts/weekly-interview-prep.mjs",
    "notify:interview": "node scripts/weekly-interview-prep.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "jose": "^5.2.0",
    "resend": "^6.10.0",
    "stripe": "^14.0.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
